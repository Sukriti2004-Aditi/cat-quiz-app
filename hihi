<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Hi Arpit 💖</title>

<style>
body{
margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
font-family:"Segoe UI", cursive;
background:linear-gradient(135deg,#ff9a9e,#fad0c4,#fbc2eb,#a6c1ee);
overflow:hidden;
}

/* Love letter card */
.card{
background:rgba(255,255,255,0.9);
padding:40px;
border-radius:20px;
text-align:center;
max-width:450px;
box-shadow:0 10px 40px rgba(0,0,0,0.2);
}

h1{
color:#ff4d6d;
margin-bottom:10px;
}

.question{
font-size:20px;
margin:20px 0;
}

button{
padding:12px 24px;
margin:10px;
border:none;
border-radius:25px;
background:#ff4d6d;
color:white;
font-size:16px;
cursor:pointer;
transition:0.3s;
}

button:hover{
transform:scale(1.1);
background:#ff1f4d;
}

/* Floating hearts */

.heart{
position:absolute;
font-size:20px;
animation:float 8s linear infinite;
opacity:0.7;
}

@keyframes float{
from{
transform:translateY(110vh);
}
to{
transform:translateY(-10vh);
}
}

/* glitter sparkles */

.sparkle{
position:absolute;
width:6px;
height:6px;
background:white;
border-radius:50%;
animation:glitter 4s linear infinite;
}

@keyframes glitter{
0%{opacity:0;transform:scale(0.5)}
50%{opacity:1;transform:scale(1.5)}
100%{opacity:0;transform:scale(0.5)}
}

</style>
</head>

<body>

<div class="card">

<h1>Hi Arpit 💖</h1>

<div id="quiz">

<div class="question" id="question">
Do you like her? 😊
</div>

<button onclick="answer(true)">Yes 💗</button>
<button onclick="answer(false)">No 🙈</button>

</div>

</div>

<script>

let step=0

const questions=[
"Do you like her? 😊",
"Do you think she is cute? 🥺",
"Will you give her a puchi? 😘",
"Will you make her smile forever? 💕"
]

function answer(choice){

if(choice){
alert("Aww that's sweet 💖")
}else{
alert("Hmm... think again 😌")
}

step++

if(step<questions.length){
document.getElementById("question").innerText=questions[step]
}else{
document.getElementById("quiz").innerHTML=
"<h2>Yay 💖</h2><p>This was the cutest little quiz ever ✨</p>"
}

}

/* generate hearts */

for(let i=0;i<40;i++){
let heart=document.createElement("div")
heart.classList.add("heart")
heart.innerHTML="💖"
heart.style.left=Math.random()*100+"vw"
heart.style.animationDuration=(5+Math.random()*5)+"s"
heart.style.fontSize=(14+Math.random()*26)+"px"
document.body.appendChild(heart)
}

/* generate glitter */

for(let i=0;i<60;i++){
let sparkle=document.createElement("div")
sparkle.classList.add("sparkle")
sparkle.style.left=Math.random()*100+"vw"
sparkle.style.top=Math.random()*100+"vh"
sparkle.style.animationDuration=(2+Math.random()*3)+"s"
document.body.appendChild(sparkle)
}

</script>

</body>
</html>
